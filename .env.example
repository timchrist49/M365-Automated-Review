# Azure App Registration (Your Tenant)
AZURE_CLIENT_ID=your-app-client-id-here
AZURE_TENANT_ID=your-tenant-id-here
CERT_PASSWORD=your-certificate-password-here

# App URLs
APP_BASE_URL=https://your-domain.com
REDIRECT_URI=https://your-domain.com/auth/callback

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here

# Email — sent from your own M365 mailbox via SMTP AUTH
# See docs/SETUP.md Part 5 for setup: enabling SMTP AUTH on your tenant/mailbox
# and generating an App Password if MFA is enforced on the sending account.
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=assessments@yourcompany.com
SMTP_PASSWORD=your-mailbox-password-or-app-password
EMAIL_FROM=assessments@yourcompany.com
EMAIL_FROM_NAME=Your Company Security Team

# Redis
REDIS_URL=redis://redis:6379/0

# Security
SECRET_KEY=generate-a-long-random-string-here  # Min 32 bytes; generate with: openssl rand -hex 32

# Paths (inside Docker)
CERT_PATH=/app/certs/monkey365.pfx
# Note: No AZURE_CLIENT_SECRET — this app uses certificate auth only (required for SharePoint on Linux)
