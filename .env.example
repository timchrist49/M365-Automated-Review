# ============================================================
# M365 Security Audit Platform — Environment Variables
# Copy this file to .env and fill in every value before running.
# See docs/SETUP.md for full setup instructions.
# ============================================================

# ------------------------------------------------------------
# Azure App Registration  (from SETUP.md Part 3)
# ------------------------------------------------------------
AZURE_CLIENT_ID=your-app-client-id-here
AZURE_TENANT_ID=your-own-tenant-id-here

# ------------------------------------------------------------
# Certificate auth  (from SETUP.md Part 2)
# Path is inside the Docker container — do not change unless you know what you're doing.
# ------------------------------------------------------------
CERT_PATH=/app/certs/monkey365.pfx
CERT_PASSWORD=your-certificate-password-here

# ------------------------------------------------------------
# App URLs — must match your domain and the Azure redirect URI exactly
# (from SETUP.md Part 3.1 and Part 4)
# ------------------------------------------------------------
APP_BASE_URL=https://your-domain.com
REDIRECT_URI=https://your-domain.com/auth/callback

# ------------------------------------------------------------
# CORS — comma-separated list of allowed origins
# Defaults to APP_BASE_URL if not set. Set explicitly in production.
# ------------------------------------------------------------
ALLOWED_ORIGINS=https://your-domain.com

# ------------------------------------------------------------
# OpenAI
# ------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key-here

# ------------------------------------------------------------
# Email — sent via Microsoft Graph API using the App Registration certificate.
# No SMTP credentials needed. Requires Mail.Send application permission.
# See docs/SETUP.md Part 5 for the one-time Azure setup.
# ------------------------------------------------------------
EMAIL_FROM=assessments@yourcompany.com
EMAIL_FROM_NAME=Your Company Security Team
# Admin email — receives a BCC copy of every client report and all failure alerts
ADMIN_EMAIL=admin@yourcompany.com

# ------------------------------------------------------------
# PostgreSQL  (used by Docker Compose — change the password, keep the rest as-is)
# ------------------------------------------------------------
POSTGRES_PASSWORD=change-this-to-a-strong-random-password
DATABASE_URL=postgresql://m365audit:change-this-to-a-strong-random-password@postgres:5432/m365audit

# ------------------------------------------------------------
# Redis  (Docker Compose internal — do not change)
# ------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# ------------------------------------------------------------
# Security
# Generate with: openssl rand -hex 32
# This has no default — the app will refuse to start without it.
# ------------------------------------------------------------
SECRET_KEY=generate-with-openssl-rand-hex-32
