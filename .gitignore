# Environment
.env
*.env

# Certificates — NEVER commit private keys
certs/*.pfx
certs/*.pem
certs/*.key
certs/*.cer
!certs/.gitkeep
nginx/certs/

# Python
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.venv/
venv/
*.egg-info/
dist/
htmlcov/
.coverage

# Node
node_modules/
frontend/dist/
frontend/.vite/

# Temp audit output
/tmp/monkey365/

# Audit output files (if accidentally run outside Docker)
output/
reports/
# Scope JSON exclusion to audit output directories only (not package.json etc.)
output/*.json
reports/*.json

# SQLite database
*.db
*.sqlite3

# IDE
.idea/
.vscode/
*.swp
